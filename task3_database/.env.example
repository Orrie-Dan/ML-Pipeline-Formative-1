# Copy this file to .env and fill in your real credentials.
# .env is git-ignored — never commit real credentials.

# --- MySQL (e.g. Railway) ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=energy_db

# --- MongoDB (e.g. Atlas M0) ---
MONGO_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net
MONGO_DB_NAME=energy_db
MONGO_COLLECTION=energy_readings
